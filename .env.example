# ============================================================
# Crypto AI System - Step150 Spreadsheet-First Guarded Template
# ============================================================

APP_ENV=local
TIMEZONE=Asia/Ho_Chi_Minh
REPORT_TIMEZONE=Asia/Seoul
TRADING_MODE=paper
DRY_RUN=true
LOG_LEVEL=INFO

SYMBOL=BTCUSDT
TIMEFRAME=1h
DEFAULT_EXCHANGE=binance

# Real market data is disabled by default.
BINANCE_MARKET_DATA_ENABLED=false
BINANCE_PUBLIC_BASE_URL=https://api.binance.com

COINALYZE_ENABLED=false
COINALYZE_API_KEY=

# Spreadsheet-first storage
SPREADSHEET_ENABLED=false
SPREADSHEET_PROVIDER=local_csv
SPREADSHEET_ID=
SPREADSHEET_WORKSHEET_PREFIX=
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=
SPREADSHEET_BATCH_SIZE=50
SPREADSHEET_MAX_RETRY=5

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

PAPER_ENGINE_ENABLED=true
PAPER_TRADING_ENABLED=true
RISK_PER_TRADE=0.01
MAX_OPEN_POSITIONS=1

DAILY_MAX_LOSS_R=-2.0
WEEKLY_MAX_LOSS_R=-5.0
MAX_CONSECUTIVE_LOSSES=3
MAX_DRAWDOWN_PCT=-10.0

MAX_STALE_DATA_MINUTES=180
MIN_CANDLE_COUNT=50
EXPECTED_CANDLE_INTERVAL_MINUTES=60
MAX_ALLOWED_CANDLE_GAP_MULTIPLE=1.5
BLOCK_SYNTHETIC_DATA_FOR_TRADING=true
BLOCK_FALLBACK_DATA_FOR_TRADING=true

# ATR / paper engine
ATR_PERIOD=14
ATR_MULTIPLIER=1.5
MIN_STOP_LOSS_BPS=35
MAX_STOP_LOSS_BPS=250
POSITION_SIZE_ACCOUNT_EQUITY_USDT=1000
MAX_POSITION_NOTIONAL_USDT=100

# Execution guard
EXCHANGE_ORDER_ENABLED=false
LIVE_TRADING_ENABLED=false
ALLOW_LIVE_TRADING=false
ENABLE_REAL_ORDERS=false
ENABLE_TESTNET_ORDERS=false
LIVE_TRADING_CONFIRMATION=
LIVE_TRADING_CONFIRMATION_PHRASE=I_UNDERSTAND_THIS_PLACES_REAL_ORDERS

BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BINANCE_TESTNET_BASE_URL=https://testnet.binancefuture.com

MAX_LIVE_POSITION_USDT=20
MAX_ORDER_NOTIONAL_USDT=20
MAX_DAILY_LOSS_USDT=10
MAX_WEEKLY_LOSS_USDT=30
MAX_LIVE_TRADES_PER_DAY=3

LIVE_SHADOW_MODE=true
SLIPPAGE_ASSUMPTION_BPS=8
FEE_ASSUMPTION_BPS=4
LATENCY_ASSUMPTION_MS=750

STORAGE_DIR=storage
DATA_DIR=data
REPORTS_DIR=reports
SECRETS_DIR=secrets
