# ============================================================
# Crypto AI System - Step1~157E Extended Merged Template
# ============================================================

APP_ENV=local
TIMEZONE=Asia/Ho_Chi_Minh
REPORT_TIMEZONE=Asia/Seoul
TRADING_MODE=paper
DRY_RUN=true
LOG_LEVEL=INFO

# Canonical market identity for Extended Perp DEX
SYMBOL=BTC-PERP
DEFAULT_SYMBOL=BTC-PERP
DEFAULT_CANONICAL_SYMBOL=BTC-PERP
DEFAULT_EXCHANGE=extended
DEFAULT_EXCHANGE_MARKET=BTC-USD
DEFAULT_TIMEFRAME=PT1H
TIMEFRAME=PT1H
DEFAULT_LIMIT=500
BASE_ASSET=BTC
QUOTE_ASSET=USD
SETTLEMENT_ASSET=USDC
CONTRACT_TYPE=PERPETUAL

# Extended API - read-only data by default
EXTENDED_ENVIRONMENT=mainnet
EXTENDED_API_BASE_URL=https://api.starknet.extended.exchange/api/v1
EXTENDED_API_KEY=
EXTENDED_USER_AGENT=crypto_ai_system_step1_157e_extended/0.1
ALLOW_SAMPLE_FALLBACK=true

# Coinalyze remains as optional auxiliary derivatives data source
COINALYZE_ENABLED=false
COINALYZE_API_KEY=
COINALYZE_SYMBOL=BTCUSDT_PERP.A
COINALYZE_EXCHANGE=binance
COINALYZE_INTERVAL=1hour

# Legacy Binance fields are kept only for backward compatibility.
# Binance is no longer the default market-data source in the Extended roadmap.
BINANCE_MARKET_DATA_ENABLED=false
BINANCE_PUBLIC_BASE_URL=https://api.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BINANCE_TESTNET_BASE_URL=https://testnet.binancefuture.com

# Spreadsheet-first storage
SPREADSHEET_ENABLED=false
SPREADSHEET_PROVIDER=local_csv
SPREADSHEET_ID=
SPREADSHEET_WORKSHEET_PREFIX=
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=
SPREADSHEET_BATCH_SIZE=50
SPREADSHEET_MAX_RETRY=5

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

PAPER_ENGINE_ENABLED=true
PAPER_TRADING_ENABLED=true
USE_RESEARCH_SIGNAL_GATE=true
RISK_LEVEL_REDUCED_POSITION_MULTIPLIER=0.50
RISK_LEVEL_BLOCKED_POSITION_MULTIPLIER=0.00
RISK_PER_TRADE=0.01
MAX_OPEN_POSITIONS=1

DAILY_MAX_LOSS_R=-2.0
WEEKLY_MAX_LOSS_R=-5.0
MAX_CONSECUTIVE_LOSSES=3
MAX_DRAWDOWN_PCT=-10.0

MAX_STALE_DATA_MINUTES=180
MIN_CANDLE_COUNT=50
EXPECTED_CANDLE_INTERVAL_MINUTES=60
MAX_ALLOWED_CANDLE_GAP_MULTIPLE=1.5
BLOCK_SYNTHETIC_DATA_FOR_TRADING=true
BLOCK_FALLBACK_DATA_FOR_TRADING=true

# ATR / paper engine
ATR_PERIOD=14
ATR_MULTIPLIER=1.5
MIN_STOP_LOSS_BPS=35
MAX_STOP_LOSS_BPS=250
POSITION_SIZE_ACCOUNT_EQUITY_USDC=1000
MAX_POSITION_NOTIONAL_USDC=100
# Legacy aliases retained for existing modules
POSITION_SIZE_ACCOUNT_EQUITY_USDT=1000
MAX_POSITION_NOTIONAL_USDT=100

# Backtest assumptions for Extended
MAKER_FEE_BPS=0
TAKER_FEE_BPS=2.5
SLIPPAGE_BPS=3
FEE_ASSUMPTION_BPS=2.5
SLIPPAGE_ASSUMPTION_BPS=3
LATENCY_ASSUMPTION_MS=750

# Execution guard: real orders remain blocked by default
EXCHANGE_ORDER_ENABLED=false
LIVE_TRADING_ENABLED=false
ALLOW_LIVE_TRADING=false
ENABLE_REAL_ORDERS=false
ENABLE_TESTNET_ORDERS=false
TESTNET_SIGNED_ORDER_ENABLED=false
LIVE_TRADING_CONFIRMATION=
LIVE_TRADING_CONFIRMATION_PHRASE=I_UNDERSTAND_THIS_PLACES_REAL_ORDERS

# --- Signed testnet order path (Binance USD-M Futures TESTNET only) ---------
# Fill these to place a real testnet order (fake funds). Leave blank/false to
# stay fail-closed. See STATUS.md for the full runbook.
#   1) create testnet keys at https://testnet.binancefuture.com
#   2) set BINANCE_API_KEY / BINANCE_API_SECRET above
#   3) set the four flags below
# Binance BTCUSDT min notional is ~100 USDT, so the cap must be raised
# (testnet fake money) or the order is blocked by the final guard.
#   TESTNET_SIGNED_ORDER_ENABLED=true
#   SIGNED_TESTNET_PLACE_ORDER_ENABLED=true
#   LIVE_TRADING_CONFIRMATION=I_UNDERSTAND_THIS_PLACES_REAL_ORDERS
#   SIGNED_TESTNET_MAX_ORDER_NOTIONAL_USDT=150
SIGNED_TESTNET_PLACE_ORDER_ENABLED=false
SIGNED_TESTNET_MAX_ORDER_NOTIONAL_USDT=5
SIGNED_TESTNET_MAX_DAILY_ORDER_COUNT=3

# --- Live canary preparation (read-only probe; grants no order authority) ---
# Requires >= LIVE_CANARY_MIN_CLEAN_TESTNET_SESSIONS clean testnet sessions
# (run_testnet_session.py) before it can pass. Use a SEPARATE live API key
# with reading only — withdrawals/transfers must be disabled on the key.
#   py scripts/check_live_canary_readiness.py --probe
# Strategy factory live routing (SHADOW mode only): when true, the pipeline
# runs the multi-strategy router over the live feature row each cycle and writes
# storage/latest/strategy_routing.json for observability. It drives no orders —
# turning a routed candidate into a paper entry is a separate later step. Reads
# the active pool from storage/latest/active_strategy_pool.json.
STRATEGY_FACTORY_ROUTING_ENABLED=false
# Drive mode (paper only): a routed candidate becomes an actual paper entry,
# still gated by research permission + PreOrderRiskGate (fail-closed if either
# refuses). Requires STRATEGY_FACTORY_ROUTING_ENABLED=true as well.
STRATEGY_FACTORY_ROUTING_DRIVE_ENABLED=false

LIVE_READONLY_PROBE_ENABLED=false
LIVE_BINANCE_API_KEY=
LIVE_BINANCE_API_SECRET=
LIVE_BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
LIVE_BINANCE_SPOT_BASE_URL=https://api.binance.com
LIVE_CANARY_MIN_CLEAN_TESTNET_SESSIONS=5

# Live canary ORDER boundary (places ONE real mainnet order — operator only, via
# run_live_canary_order.py --confirm, and only after the preparation gate is READY).
# All fail-closed; use a SEPARATE order-capable key from the read-only probe key,
# and note the confirmation phrase is DISTINCT from the testnet one.
#   LIVE_CANARY_ENABLED=true
#   LIVE_CANARY_PLACE_ORDER_ENABLED=true
#   LIVE_CANARY_CONFIRMATION=I_UNDERSTAND_THIS_PLACES_A_REAL_LIVE_MAINNET_ORDER
#   LIVE_CANARY_API_KEY=... / LIVE_CANARY_API_SECRET=...
#   LIVE_CANARY_MAX_ORDER_NOTIONAL_USDT=150   # <= LIVE_CANARY_ABSOLUTE_MAX_NOTIONAL_USDT
LIVE_CANARY_ENABLED=false
LIVE_CANARY_PLACE_ORDER_ENABLED=false
LIVE_CANARY_MANUAL_KILL_SWITCH=false
LIVE_CANARY_CONFIRMATION=
LIVE_CANARY_CONFIRMATION_PHRASE=I_UNDERSTAND_THIS_PLACES_A_REAL_LIVE_MAINNET_ORDER
LIVE_CANARY_API_KEY=
LIVE_CANARY_API_SECRET=
LIVE_CANARY_BASE_URL=https://fapi.binance.com
LIVE_CANARY_MAX_ORDER_NOTIONAL_USDT=5
LIVE_CANARY_ABSOLUTE_MAX_NOTIONAL_USDT=200
LIVE_CANARY_MAX_DAILY_ORDER_COUNT=1

# Autonomous live STRATEGY trading (L1-L6). The most dangerous boundary in the
# system: strategy signals place real mainnet orders on a schedule. Every flag is
# fail-closed; ALL of these must be set (plus >=LIVE_STRATEGY_MIN_CLEAN_CANARY_ORDERS
# clean canary orders on record, plus strategy routing+drive enabled) or the
# pipeline refuses the live stage. Uses ITS OWN key and confirmation phrase —
# neither the canary's nor the testnet's can authorize it. The daily-loss limit
# is a hard circuit breaker: 0 (unset) blocks live entirely.
LIVE_STRATEGY_ORDER_ENABLED=false
LIVE_STRATEGY_PLACE_ORDER_ENABLED=false
LIVE_STRATEGY_MANUAL_KILL_SWITCH=false
LIVE_STRATEGY_CONFIRMATION=
LIVE_STRATEGY_CONFIRMATION_PHRASE=I_UNDERSTAND_THIS_TRADES_LIVE_FUNDS_AUTONOMOUSLY
LIVE_STRATEGY_API_KEY=
LIVE_STRATEGY_API_SECRET=
LIVE_STRATEGY_BASE_URL=https://fapi.binance.com
LIVE_STRATEGY_MAX_ORDER_NOTIONAL_USDT=0
LIVE_STRATEGY_ABSOLUTE_MAX_NOTIONAL_USDT=200
LIVE_STRATEGY_MAX_DAILY_ORDER_COUNT=0
LIVE_STRATEGY_MAX_OPEN_NOTIONAL_USDT=0
LIVE_STRATEGY_DAILY_LOSS_LIMIT_USDT=0
LIVE_STRATEGY_MIN_CLEAN_CANARY_ORDERS=3

MAX_LIVE_POSITION_USDC=20
MAX_ORDER_NOTIONAL_USDC=20
MAX_DAILY_LOSS_USDC=10
MAX_WEEKLY_LOSS_USDC=30
# Legacy aliases retained for existing modules
MAX_LIVE_POSITION_USDT=20
MAX_ORDER_NOTIONAL_USDT=20
MAX_DAILY_LOSS_USDT=10
MAX_WEEKLY_LOSS_USDT=30
MAX_LIVE_TRADES_PER_DAY=3

LIVE_SHADOW_MODE=true

STORAGE_DIR=storage
DATA_DIR=data
REPORTS_DIR=reports
SECRETS_DIR=secrets

# Stable merged package health profile
# stable = Step1~157E main path; legacy = older Step1~150 daily runner requirements
SCHEDULER_HEALTH_PROFILE=stable


# Additional data collectors for BTC ResearchSignal v2
ADDITIONAL_DATA_ENABLED=true
ADDITIONAL_DATA_NETWORK_ENABLED=false
ADDITIONAL_DATA_TIMEOUT_SECONDS=1.5
BINANCE_FUTURES_PUBLIC_ENABLED=true
BINANCE_FUTURES_PUBLIC_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_SYMBOL=BTCUSDT
BINANCE_FUTURES_PERIOD=1h
BINANCE_FUTURES_LIMIT=100
COINMETRICS_ENABLED=true
COINMETRICS_BASE_URL=https://community-api.coinmetrics.io/v4
COINMETRICS_ASSET=btc
COINMETRICS_FREQUENCY=1d
COINMETRICS_PAGE_SIZE=200
FARSIDE_ETF_FLOW_ENABLED=false
FARSIDE_BTC_ETF_FLOW_CSV=data/raw/etf/farside_btc_etf_flow.csv
DEFILLAMA_STABLECOINS_ENABLED=true
DEFILLAMA_STABLECOINS_BASE_URL=https://stablecoins.llama.fi

# ------------------------------------------------------------
# Validation Runner Control
# ------------------------------------------------------------
# false: Step161/Step162 validation runners use local/offline mode
# true: Step161/Step162 validation runners call real public APIs
RUN_NETWORK_TESTS=false

# ------------------------------------------------------------
# Step162.2 timestamp-safe Feature Matrix
# live: latest optional API snapshot is applied only to the latest row
# backtest: optional features are attached only when feature_timestamp <= price_timestamp
# ------------------------------------------------------------
RESEARCH_FEATURE_MATRIX_MODE=live
FEATURE_STORE_EXTRA_DATA_ASOF_TOLERANCE=3D

# Step163: ResearchSignal v2 trade_permission is the final Trading Bot gate.
# normal = full size, reduced = size multiplier, blocked = no new position.

# ------------------------------------------------------------
# Step164 Permission Audit / Telegram / Paper Risk Report
# ------------------------------------------------------------
PERMISSION_GATE_AUDIT_ENABLED=true
PAPER_RISK_LEVEL_REPORT_ENABLED=true
TELEGRAM_INCLUDE_TRADE_PERMISSION=true
TELEGRAM_INCLUDE_PAPER_RISK_LEVEL_REPORT=true
