# ============================================================
# Core Runtime
# ============================================================
STORAGE_DIR=storage
TIMEZONE=Asia/Seoul
DAILY_REPORT_TIME=19:00

# ============================================================
# Trading Safety
# ============================================================
TRADING_MODE=paper
DRY_RUN=true

BOT_MODE=PAPER_ONLY
LIVE_TRADING_ENABLED=false
ALLOW_LIVE_TRADING=false
GLOBAL_KILL_SWITCH=false
RUNTIME_MODE=OPERATIONAL_DRY_RUN

EXCHANGE_MODE=MOCK
EXCHANGE_ORDER_ENABLED=false
ALLOW_MOCK_ORDER_IN_MANUAL_TEST=false

MAX_ORDER_USDT=10
MAX_POSITION_USDT=10
MAX_OPEN_POSITIONS=1
MAX_RECENT_LOSSES=3

# ============================================================
# Symbol / Market
# ============================================================
SYMBOL=BTCUSDT_PERP.A
TRADING_SYMBOL=BTCUSDT
INTERVAL=1hour

REAL_MARKET_DATA_ENABLED=true
ENABLE_COINALYZE=true

COINALYZE_API_KEY=
COINALYZE_BASE_URL=https://api.coinalyze.net/v1
COINALYZE_SYMBOL=BTCUSDT_PERP.A
COINALYZE_EXCHANGE=binance
COINALYZE_INTERVAL=1hour
COINALYZE_LOOKBACK_HOURS=48

# ============================================================
# Telegram
# ============================================================
ENABLE_TELEGRAM=true
TELEGRAM_ENABLED=true
SCHEDULER_HEALTH_TELEGRAM_ENABLED=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# Spreadsheet / Local Export
# ============================================================
ENABLE_SPREADSHEET_SYNC=true
SPREADSHEET_LOCAL_EXPORT=true

SPREADSHEET_EXPORT_ENABLED=true
SPREADSHEET_EXPORT_DIR=storage/spreadsheet_exports
SPREADSHEET_SYNC_AFTER_FULL_CYCLE=false

GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/google_service_account.json

# ============================================================
# Scheduler Health
# ============================================================
SCHEDULER_HEALTH_MAX_AGE_HOURS=26
SCHEDULER_HEALTH_RUN_CHECK_BEFORE_SEND=true

# ============================================================
# Forward Test
# ============================================================
FORWARD_TEST_INTERVAL_SECONDS=300
FORWARD_TEST_MAX_CYCLES=12
FORWARD_TEST_TARGET=FULL_CYCLE

# ============================================================
# Dynamic Setup Generator
# ============================================================
DYNAMIC_SETUP_MIN_SCORE=2
DYNAMIC_SETUP_PRICE_DECIMALS=2

DYNAMIC_LONG_TRIGGER_PCT=0.003
DYNAMIC_LONG_INVALIDATION_PCT=0.008
DYNAMIC_LONG_TAKE_PROFIT_PCT=0.015

DYNAMIC_SHORT_TRIGGER_PCT=0.003
DYNAMIC_SHORT_INVALIDATION_PCT=0.008
DYNAMIC_SHORT_TAKE_PROFIT_PCT=0.015

# ============================================================
# Strategy Fallbacks
# Used only when dynamic setup generation is not available.
# These are NOT live market prices.
# ============================================================
FALLBACK_TRIGGER_PRICE=107500
FALLBACK_INVALIDATION_PRICE=106200
FALLBACK_TAKE_PROFIT=110000
FALLBACK_SETUP_TYPE=breakout_reclaim
FALLBACK_SETUP_DIRECTION=long
FALLBACK_EXPIRES_AFTER_HOURS=24

# ============================================================
# Synthetic Test Market Context
# Used only for local tests, never for live operation.
# ============================================================
ALLOW_SYNTHETIC_MARKET_CONTEXT=false
SYNTHETIC_CURRENT_PRICE=106850

# ============================================================
# Order Executor Integration
# ============================================================
ORDER_EXECUTOR_INTEGRATION_ENABLED=false
ORDER_EXECUTOR_QUANTITY=0.00005

# ============================================================
# Knowledge Base
# ============================================================
KB_LINT_BLOCK_TRADING_ON_ERROR=true
KB_HOT_MAX_AGE_HOURS=24