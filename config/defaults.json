{
  "agent_id": "crypto_ai_system",
  "mode": "local_launcher",
  "default_symbols": [
    "BTC",
    "ETH"
  ],
  "default_timeframes": [
    "15m",
    "1h",
    "4h",
    "1d"
  ],
  "save_artifacts": true,
  "artifact_format": "markdown",
  "artifact_base_dir": "data/reports",
  "live_trading_enabled": false,
  "order_execution_enabled": false,
  "auto_position_open_enabled": false,
  "paper_trading_enabled": true,
  "withdrawal_enabled": false,
  "fund_transfer_enabled": false,
  "max_runtime_seconds": 300,
  "dry_run_default": true,
  "research_signal_schema_required": true,
  "strict_timestamp_validation": true,
  "strict_data_quality_check": true,
  "docker_mode_supported": true,
  "container_mode": "local_launcher",
  "docker_artifact_base_dir": "/app/crypto_ai_system/data/reports",
  "agent_os_import_supported": true,
  "agent_os_expected_top_level_dir": "crypto_ai_system",
  "agent_os_install_target": "agents_installed/crypto_ai_system/current",
  "agent_os_registry_ready_status": "ready_review_only",
  "execution_permission_granted": false,
  "stage_transition_allowed": false,
  "package_version": "0.286.0-agent.14",
  "agent_package_boundary_mode": "crypto_zip_only",
  "launcher_import_manager_implemented_here": false,
  "telegram_router_implemented_here": false,
  "report_contract_version": "agent_report_v2",
  "daily_scan_report_quality_hardened": true,
  "report_front_matter_required": true,
  "report_safety_footer_required": true,
  "neutral_due_to_missing_optional_data_required": true,
  "research_signal_contract_version": "research_signal_v2_agent_package_contract",
  "signal_command_research_signal_v2_enabled": true,
  "signal_live_eligibility_must_be_false": true,
  "signal_requires_lineage_hashes": true,
  "signal_missing_optional_data_neutral_required": true,
  "backtest_command_contract_enabled": true,
  "backtest_artifact_contract": "backtest_review_v1",
  "backtest_historical_data_only": true,
  "backtest_live_eligibility_must_be_false": true,
  "feedback_command_contract_enabled": true,
  "feedback_artifact_contract": "feedback_review_v1",
  "feedback_runtime_mutation_must_be_false": true,
  "artifact_registry_enabled": true,
  "artifact_registry_contract_version": "agent_artifact_registry_v1",
  "artifact_metadata_sidecar_contract_version": "agent_artifact_metadata_v1",
  "artifact_index_contract_version": "agent_artifact_index_v1",
  "latest_pointer_contract_version": "agent_artifact_latest_pointer_v1",
  "stdout_json_artifact_hash_required": true,
  "artifact_index_file": "artifact_index.json",
  "latest_pointer_dir": "latest",
  "paper_command_contract_enabled": true,
  "paper_artifact_contract": "paper_simulation_review_v1",
  "paper_command_requires_approval": true,
  "paper_real_execution_allowed": false,
  "paper_order_submission_must_be_false": true,
  "paper_exchange_adapter_must_be_false": true,
  "paper_signed_testnet_candidate_must_be_false": true,
  "paper_live_candidate_must_be_false": true,
  "source_health_command_enabled": true,
  "source_health_artifact_contract": "source_health_review_v1",
  "price_data_hard_required": true,
  "optional_data_missing_policy": "neutral_due_to_missing",
  "source_health_live_candidate_must_be_false": true,
  "fallback_sample_synthetic_source_must_block": true,
  "local_price_data_dir": "data/price_data",
  "local_price_data_max_age_hours": 48,
  "price_csv_schema_contract_version": "price_csv_ohlcv_v1",
  "price_csv_required_columns": [
    "timestamp",
    "symbol",
    "open",
    "high",
    "low",
    "close",
    "volume"
  ],
  "price_csv_sample_blocks_candidates": true,
  "price_csv_stale_blocks_candidates": true,
  "price_data_connected_requires_real_local_csv": true,
  "local_price_csv_dry_run_enabled": true,
  "price_feature_snapshot_enabled": true,
  "price_feature_snapshot_contract_version": "price_feature_snapshot_v1",
  "feature_snapshot_requires_valid_price_snapshot": true,
  "feature_snapshot_blocks_sample_stale_invalid_csv": true,
  "feature_snapshot_live_candidate_must_be_false": true,
  "feature_snapshot_required_for_signal_lineage": true,
  "price_feature_columns": [
    "latest_close",
    "previous_close",
    "close_return_1",
    "high_low_range_pct",
    "latest_volume",
    "row_count"
  ]
}
