data:
  exchange: extended
  canonical_symbol: BTC-PERP
  exchange_market: BTC-USD
  base_asset: BTC
  quote_asset: USD
  settlement_asset: USDC
  contract_type: PERPETUAL
  timeframe: PT1H
  limit: 500
  allow_sample_fallback: true
  extended_candle_type: trades
  collect_mark_index_candles: true
  use_coinalyze_enrichment: true
  source_priority:
  - extended
  - coinalyze
  - price_data
  - sample
  source_policy:
    live_execution_allowed_sources:
    - extended
    research_only_sources:
    - price_data_binance_tradingview
    - sample_extended
extended:
  environment: mainnet
  mainnet_base_url: https://api.starknet.extended.exchange/api/v1
  testnet_base_url: https://api.starknet.sepolia.extended.exchange/api/v1
  timeout_seconds: 10
  user_agent: crypto_ai_system_step157e/0.1
  funding_lookback_hours: 500
  oi_lookback_hours: 300
  orderbook_spread_guard_bps: 10
coinalyze:
  enabled: true
  symbol: BTCUSDT_PERP.A
  interval: 1hour
storage:
  root_dir: storage
  latest_dir: storage/latest
  backup_dir: storage/backup/spreadsheet
  queue_dir: storage/queue
  log_dir: storage/logs
  backtest_dir: storage/backtest
  raw_dir: storage/raw
  features_dir: storage/features
  signals_dir: storage/signals
  orders_dir: storage/orders
features:
  ma_fast: 20
  ma_slow: 50
  ema_fast: 20
  ema_slow: 50
  atr_period: 14
  rsi_period: 14
  adx_period: 14
  atr_percentile_window: 100
  funding_z_window: 100
  oi_change_1h_window: 1
  oi_change_4h_window: 4
entry_policy:
  bullish_threshold: 0.58
  bearish_threshold: -0.58
  adx_trend_threshold: 20
  rsi_range_long: 35
  rsi_range_short: 65
  allow_trend_entry: true
  allow_range_entry: true
  allow_liquidation_reversal: false
  funding_abs_block: 0.0008
  funding_abs_reduce: 0.0005
  oi_change_abs_block: 0.08
  oi_change_abs_reduce: 0.04
  spread_bps_block: 10
  spread_bps_reduce: 6
  exchange_flow_sell_pressure_block: 0.75
  exchange_flow_sell_pressure_reduce: 0.4
  binance_derivatives_crowding_block: 0.9
  binance_derivatives_crowding_reduce: 0.65
  etf_outflow_block: 0.85
  etf_outflow_reduce: 0.45
  stablecoin_liquidity_contraction_block: 0.85
  stablecoin_liquidity_contraction_reduce: 0.45
  risk_score_reduce: 0.45
exit_policy:
  atr_multiplier: 1.5
  min_stop_bps: 30
  max_stop_bps: 250
  tp1_r: 1.5
  tp1_size_pct: 0.5
  tp2_r: 3.0
  breakeven_enabled: true
  breakeven_after_tp1: true
  breakeven_fee_buffer_bps: 5
  trailing_enabled: true
  trailing_only_after_tp1: true
  trailing_only_in_trend: true
  trailing_atr_multiplier: 2.0
  time_stop_enabled: true
  time_stop_candles: 24
  time_stop_min_mfe_r: 0.5
backtest:
  exchange: extended
  initial_equity: 10000
  risk_per_trade_pct: 0.01
  maker_fee_bps: 0
  taker_fee_bps: 2.5
  slippage_bps: 3
  use_funding_payment: true
  funding_interval_hours: 1
  entry_price_type: next_candle_open
  liquidation_check_price_type: mark_price
parameter_sweep:
  atr_multipliers:
  - 1.2
  - 1.5
  - 2.0
  tp1_r_values:
  - 1.0
  - 1.2
  - 1.5
  - 2.0
  tp1_size_values:
  - 0.3
  - 0.5
  - 0.7
  trailing_atr_multipliers:
  - 1.5
  - 2.0
  - 2.5
  time_stop_candles:
  - 12
  - 24
  - 36
  funding_filter_modes:
  - 'off'
  - normal
  - strict
  oi_filter_modes:
  - 'off'
  - normal
  - strict
  spread_filter_bps:
  - 0
  - 5
  - 10
research:
  enabled: true
  score_weights:
    structure: 0.2
    momentum: 0.1
    derivatives: 0.25
    exchange_flow: 0.15
    etf_flow: 0.15
    stablecoin_liquidity: 0.1
    risk: 0.05
    onchain: 0.0
  calibration_review:
    mode: review_only
    auto_apply_selected_profile: false
    selected_profile_write_enabled: false
    min_rows: 24
    min_entry_allowed_ratio: 0.03
    max_entry_allowed_ratio: 0.8
    max_blocked_ratio: 0.7
    max_reduced_ratio: 0.6
    target_entry_allowed_ratio: 0.25
    target_blocked_ratio: 0.35
  score_weight_profiles:
    baseline_step258:
      structure: 0.2
      momentum: 0.1
      derivatives: 0.25
      exchange_flow: 0.15
      etf_flow: 0.15
      stablecoin_liquidity: 0.1
      risk: 0.05
      onchain: 0.0
    price_structure_dominant:
      structure: 0.35
      momentum: 0.15
      derivatives: 0.2
      exchange_flow: 0.1
      etf_flow: 0.1
      stablecoin_liquidity: 0.05
      risk: 0.05
      onchain: 0.0
    flow_confirmed:
      structure: 0.18
      momentum: 0.08
      derivatives: 0.18
      exchange_flow: 0.22
      etf_flow: 0.2
      stablecoin_liquidity: 0.09
      risk: 0.05
      onchain: 0.0
    liquidity_risk_guarded:
      structure: 0.18
      momentum: 0.08
      derivatives: 0.18
      exchange_flow: 0.16
      etf_flow: 0.16
      stablecoin_liquidity: 0.14
      risk: 0.1
      onchain: 0.0
  report_cadence:
    daily: true
    weekly: true
    monthly: true
  calibration_approval:
    mode: manual_approval_packet_review_only
    manual_approval_required: true
    approval_packet_write_enabled: true
    auto_apply_approved_profile: false
    runtime_score_weight_write_enabled: false
    settings_score_weight_write_enabled: false
    apply_approved_profile_enabled: false
    accepted_decisions:
    - APPROVE_FOR_REVIEW_ONLY_STAGING
    - REJECT
    - REQUEST_MORE_DATA
  calibration_approval_intake:
    mode: approval_intake_validator_review_only
    approval_intake_write_enabled: true
    manual_approval_required: true
    auto_apply_approved_profile: false
    runtime_score_weight_write_enabled: false
    settings_score_weight_write_enabled: false
    apply_approved_profile_enabled: false
    accepted_decisions:
    - APPROVE_FOR_REVIEW_ONLY_STAGING
    - REJECT
    - REQUEST_MORE_DATA
  calibration_staging_handoff:
    mode: review_only_staging_handoff_pre_apply_checklist
    staging_handoff_write_enabled: true
    manual_pre_apply_review_required: true
    pre_apply_checklist_required: true
    auto_apply_approved_profile: false
    runtime_score_weight_write_enabled: false
    settings_score_weight_write_enabled: false
    apply_approved_profile_enabled: false
    accepted_source_decisions:
    - APPROVE_FOR_REVIEW_ONLY_STAGING
  calibration_pre_apply_review:
    mode: manual_pre_apply_review_record_validator_disabled_apply
    pre_apply_review_record_write_enabled: true
    manual_pre_apply_review_required: true
    auto_apply_reviewed_profile: false
    runtime_score_weight_write_enabled: false
    settings_score_weight_write_enabled: false
    apply_reviewed_profile_enabled: false
    accepted_decisions:
    - READY
    - REJECT
    - REQUEST_MORE_DATA
    canonical_ready_decision: READY_FOR_DISABLED_PRE_APPLY_REVIEW
  calibration_apply_dry_run:
    mode: disabled_apply_candidate_dry_run_packet
    dry_run_packet_write_enabled: true
    manual_apply_approval_required: true
    auto_apply_candidate_profile: false
    runtime_score_weight_write_enabled: false
    settings_score_weight_write_enabled: false
    apply_candidate_profile_enabled: false
    mutation_plan_write_enabled: true
    diff_required: true
    accepted_source_record_statuses:
    - ready_for_disabled_pre_apply_review
  calibration_final_apply_approval:
    mode: final_manual_apply_approval_validator_disabled_apply
    final_apply_approval_record_write_enabled: true
    manual_final_apply_approval_required: true
    auto_apply_approved_profile: false
    runtime_score_weight_write_enabled: false
    settings_score_weight_write_enabled: false
    apply_approved_profile_enabled: false
    accepted_decisions:
    - APPROVE_DRY_RUN
    - REJECT
    - REQUEST_MORE_DATA
    canonical_approve_decision: APPROVED_DISABLED_APPLY_DRY_RUN
    accepted_source_dry_run_statuses:
    - ready_disabled_apply_dry_run
  calibration_settings_write_preview:
    mode: disabled_settings_write_preview_export_only
    settings_write_preview_export_enabled: true
    manual_settings_write_review_required: true
    auto_apply_approved_profile: false
    runtime_score_weight_write_enabled: false
    settings_score_weight_write_enabled: false
    config_write_enabled: false
    settings_file_write_enabled: false
    apply_preview_enabled: false
    accepted_source_record_statuses:
    - approved_disabled_apply_dry_run
    target_yaml_path: research.score_weights
    target_settings_file: config/settings.yaml
trading:
  mode: paper
  allow_live_orders: false
  use_research_signal_gate: true
  risk_level_reduced_position_multiplier: 0.5
  risk_level_blocked_position_multiplier: 0.0
  max_position_usdc: 1000
  max_daily_loss_usdc: 100
  max_consecutive_losses: 3
telegram:
  enabled: false
  dry_run: true
price_data:
  enabled: true
  directory: data/price_data/BINANCE_BTCUSDT_P
  primary_timeframe: 1h
  use_as_fallback_for_ohlcv: true
  include_multi_timeframe_context: true
  files:
    15m: btcusdtp_15m.csv
    1h: btcusdtp_1h.csv
    4h: btcusdtp_4h.csv
    1d: btcusdtp_1d.csv
    3d: btcusdtp_3d.csv
    1w: btcusdtp_1w.csv
    1m: btcusdtp_1m.csv
  timeframe_weights:
    15m: 0.5
    1h: 1.0
    4h: 1.5
    1d: 2.0
    3d: 2.0
    1w: 2.5
    1m: 2.5
additional_data:
  enabled: true
  network_enabled: false
  health:
    max_age_sec: 259200
    binance_futures:
      max_age_sec: 21600
    coinmetrics_exchange_flow:
      max_age_sec: 259200
    farside_etf_flow:
      max_age_sec: 604800
    defillama_stablecoins:
      max_age_sec: 259200
  timeout_seconds: 1.5
  binance_futures:
    enabled: true
    base_url: https://fapi.binance.com
    symbol: BTCUSDT
    pair: BTCUSDT
    contract_type: PERPETUAL
    period: 1h
    kline_interval: 1h
    limit: 100
    depth_limit: 100
    request_pause_seconds: 0
    abort_after_errors: 2
  coinmetrics:
    enabled: true
    base_url: https://community-api.coinmetrics.io/v4
    asset: btc
    frequency: 1d
    page_size: 200
    exchange_flow_metrics:
      binance:
        native: FlowNetBNBNtv
        usd: FlowNetBNBUSD
      coinbase:
        native: FlowNetCBSNtv
        usd: FlowNetCBSUSD
      okx:
        native: FlowNetOKXNtv
        usd: FlowNetOKXUSD
      bybit:
        native: FlowNetBITNtv
        usd: FlowNetBITUSD
      kraken:
        native: FlowNetKRKNtv
        usd: FlowNetKRKUSD
  farside:
    enabled: false
    csv_path: data/raw/etf/farside_btc_etf_flow.csv
  defillama:
    enabled: true
    base_url: https://stablecoins.llama.fi
feature_store:
  extra_data_asof_tolerance: 3D
  research_matrix_mode: live
audit:
  permission_gate_audit_enabled: true
  permission_gate_audit_path: storage/logs/permission_gate_audit.jsonl
  latest_permission_gate_audit_path: storage/latest/permission_gate_audit_latest.json
paper_report:
  risk_level_report_enabled: true
  risk_level_report_path: storage/latest/paper_risk_level_report.json
validation:
  full_regression_runtime_hygiene:
    step: 280
    strategy: chunked_pytest_suites_with_progress_and_runtime_report
    single_pytest_tests_command_replaced_in_ci: true
    focused_regression_latest_step: 280
    full_pytest_completed_green_required_before_signed_testnet_execution: true
    live_trading_enabled: false
    testnet_order_submission_allowed: false
    external_order_submission_allowed: false
    settings_write_enabled: false
    score_weights_mutation_allowed: false
  explicit_signed_testnet_execution_approval_packet:
    step: 281
    stage: review_only_explicit_signed_testnet_execution_approval_packet
    require_step279_probe_result_summary: true
    require_step280_full_regression_report: true
    signed_testnet_execution_allowed: false
    testnet_order_submission_allowed: false
    external_order_submission_allowed: false
    settings_write_enabled: false
    score_weights_mutation_allowed: false
